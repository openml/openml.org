#     remoteRef:
#       key: openml/prod/nextjs/database-url
#   - secretKey: SESSION_SECRET
#     remoteRef:
#       key: openml/prod/nextjs/session-secret
#   - secretKey: NEXTAUTH_SECRET
#     remoteRef:
#       key: openml/prod/nextjs/nextauth-secret
#   - secretKey: GITHUB_SECRET
#     remoteRef:
#       key: openml/prod/nextjs/github-secret
#   - secretKey: GOOGLE_SECRET
#     remoteRef:
#       key: openml/prod/nextjs/google-secret
